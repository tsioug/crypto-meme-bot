# Required secrets (Telegram user account + alert bot)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION=data/meme.session
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=

# Data paths
DATA_DIR=data
DB_PATH=data/meme.db
CHANNELS_PATH=channels.yaml
STOP_PATH=data/STOP

# Aggregation thresholds
WINDOW_MINUTES=5
MIN_MENTIONS=5
MIN_POSITIVE_RATIO=0.70
ALERT_COOLDOWN_MINUTES=30
POSITIVE_COMPOUND_THRESHOLD=0.05
MAX_CAS_PER_MESSAGE=3

# Discover process
DISCOVER_INTERVAL_HOURS=12
DISCOVER_KEYWORDS=solana,memecoin,pumpfun

# Debug
VERBOSE=false
